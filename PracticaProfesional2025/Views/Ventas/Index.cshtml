@model PracticaProfesional2025.ViewModels.VentaViewModel
@using PracticaProfesional2025.Models
@using Newtonsoft.Json

@{
    ViewData["Title"] = "Registrar Venta";
}


<div class="container mt-4">

    @if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

    @if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
    <h2 class="text-danger fw-bold mb-3"><i class="bi bi-cash-stack"></i> Nueva Venta</h2>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <form asp-action="@(Model.EditIndex != null ? "GuardarEdicion" : "AgregarProducto")"
                  method="post"
                  class="row g-3">

                @if (Model.EditIndex != null)
                {
                    <input type="hidden" name="index" value="@Model.EditIndex" />
                }

                <!-- PRODUCTO -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Producto</label>

                    <select name="ProductoId" id="ProductoId" class="form-select" required>

                        <option value="">-- Seleccione --</option>

                        @foreach (var p in ViewBag.Productos)
                        {
                            if (Model.ProductoEditarId == p.Id)
                            {
                                <option value="@p.Id" selected>
                                    @p.Nombre
                                </option>
                            }
                            else
                            {
                                <option value="@p.Id">
                                    @p.Nombre
                                </option>
                            }
                        }
                    </select>
                </div>

                <!-- TIPO -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Tipo de Venta</label>

                    <input type="text"
                           id="TipoVenta"
                           name="TipoVenta"
                           class="form-control"
                           readonly />
                </div>

                <!-- CANTIDAD -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Valor / Cantidad</label>

                    <input type="number"
                           step="1"
                           name="Cantidad"
                           id="Cantidad"
                           class="form-control"
                           value="@Model.CantidadEditar"
                           required />
                </div>

                <!-- BOTÓN -->
                <div class="col-md-2 d-flex align-items-end">

                    @if (Model.EditIndex != null)
                    {
                        <button type="submit" class="btn btn-warning w-100">
                            <i class="bi bi-save"></i> Guardar 
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            Cancelar
                        </a>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="bi bi-cart-plus"></i> Agregar
                        </button>
                    }

                </div>

            </form>

        </div>
    </div>

    <!-- ======================== -->
    <!--   SCRIPT INDEX VIEW      -->
    <!-- ======================== -->
    <script>
        const productos = @Html.Raw(JsonConvert.SerializeObject(ViewBag.Productos));

        const selectProducto = document.getElementById("ProductoId");
        const tipoInput = document.getElementById("TipoVenta");

        function actualizarTipoVenta() {

            const producto = productos.find(p => p.Id == selectProducto.value);

            if (producto) {
                tipoInput.value = producto.Tipo;
            }
            else {
                tipoInput.value = "";
            }
        }

        selectProducto.addEventListener("change", actualizarTipoVenta);

        // IMPORTANTE:
        // ejecuta automáticamente al cargar
        actualizarTipoVenta();

    </script>


    <!-- ======================== -->
    <!--   TABLA DETALLES        -->
    <!-- ======================== -->

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h5 class="fw-semibold mb-3 text-secondary">Detalles de la venta</h5>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Tipo</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                        <th>Fecha</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Detalles != null && Model.Detalles.Any())
                    {
                        foreach (var item in Model.Detalles)
                        {
                            <tr>
                                <td>@item.NombreProducto</td>
                                <td>@item.TipoVenta</td>
                                <td>@item.Cantidad.ToString("0.###")</td>
                                <td>$@item.Subtotal</td>
                                <td>@item.Fecha.ToShortDateString()</td>
                                <td class="d-flex gap-1">

                                    <form asp-action="EditarDetalle" method="get">
                                        <input type="hidden" name="index" value="@Model.Detalles.IndexOf(item)" />

                                        <button type="submit" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </form>

                                    <form asp-action="EliminarDetalle" method="post">
                                        <input type="hidden" name="index" value="@Model.Detalles.IndexOf(item)" />

                                        <button type="submit"
                                                class="btn btn-sm btn-danger"
                                                onclick="return confirm('¿Deseas eliminar este producto de la venta?')">
                                        <i class="bi bi-trash"></i>
                                        </button>

                                    </form>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No hay productos agregados</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <div class="text-end mt-3">
                <h4 class="text-danger fw-bold">
                    Total: $
                    @((Model.Detalles != null) ? Model.Detalles.Sum(x => x.Subtotal) : 0)
                </h4>

                <form asp-action="ConfirmarVenta" method="post">
                    <button type="submit" class="btn btn-success mt-2">
                        <i class="bi bi-check-circle"></i> Finalizar Venta
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>


