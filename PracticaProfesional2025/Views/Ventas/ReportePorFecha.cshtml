@model List<PracticaProfesional2025.ViewModels.ReporteDiaViewModel>

<h2 class="mb-4">Reporte de Ventas por Fechas</h2>

<form method="get" asp-action="ReportePorFecha" class="mb-4 row g-2">
    <div class="col-md-4">
        <label class="form-label">Desde:</label>
        <input type="date" name="desde" class="form-control" value="@ViewBag.Desde?.ToString("yyyy-MM-dd")" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Hasta:</label>
        <input type="date" name="hasta" class="form-control" value="@ViewBag.Hasta?.ToString("yyyy-MM-dd")" />
    </div>

    <div class="col-md-4 d-flex align-items-end">
        <button class="btn btn-primary w-100" type="submit">Buscar</button>
    </div>
</form>
@if (Model.Any())
{
    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Total vendido</h6>
                    <h3>$@Model.First().TotalGeneral.ToString("0.##")</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Registros</h6>
                    <h3>@Model.First().CantidadVentas</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Producto más vendido</h6>
                    <strong>@Model.First().ProductoUnidadTop</strong>

                    <div>
                        @Model.First().CantidadUnidadTop.ToString("0.##")
                        unidades
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Producto KG top</h6>
                    <strong>@Model.First().ProductoKgTop</strong>

                    <div>
                        $@Model.First().TotalKgTop.ToString("0.##")
                    </div>
                </div>
            </div>
        </div>

    </div>
}
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">

        <h5 class="mb-4">
            Productos más vendidos (unidad)
        </h5>

        <canvas id="ventasChart" height="120"></canvas>

    </div>
</div>
<div class="row">

    <!-- KG -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">

                <h5 class="mb-4">
                    Productos KG más rentables
                </h5>

                <canvas id="kgChart"></canvas>

            </div>
        </div>
    </div>

    <!-- VENTAS POR DIA -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">

                <h5 class="mb-4">
                    Ventas por día
                </h5>

                <canvas id="diasChart"></canvas>

            </div>
        </div>
    </div>

</div>
@if (!Model.Any())
{
    <p class="text-danger">No se encontraron ventas en ese rango.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Total del Día</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td>@d.Fecha.ToShortDateString()</td>
                    <td>$@d.TotalDia</td>
                    <td>
                        <a asp-action="DetallePorDia"
                           asp-route-fecha="@d.Fecha.ToString("yyyy-MM-dd")"
                           asp-route-desde="@ViewBag.Desde?.ToString("yyyy-MM-dd")"
                           asp-route-hasta="@ViewBag.Hasta?.ToString("yyyy-MM-dd")"
                           class="btn btn-primary btn-sm">
                            Ver detalles
                        </a>

                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (ViewBag.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="ReportePorFecha"
                           asp-route-page="@i"
                           asp-route-desde="@ViewBag.Desde?.ToString("yyyy-MM-dd")"
                           asp-route-hasta="@ViewBag.Hasta?.ToString("yyyy-MM-dd")">
                            @i
                        </a>
                    </li>
                }

            </ul>
        </nav>
    }
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>

        // =========================
        // KG CHART
        // =========================

        const kgLabels = @Html.Raw(
                    Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GraficoKgLabels)
            );

    const kgData = @Html.Raw(
                Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GraficoKgData)
        );

    new Chart(document.getElementById('kgChart'), {

            type: 'bar',

            data: {
                labels: kgLabels,

                datasets: [{
                    label: 'Dinero generado',
                    data: kgData,
                    borderWidth: 1
                }]
            },

            options: {
                responsive: true
            }
        });

        // =========================
        // VENTAS POR DIA
        // =========================

        const diasLabels = @Html.Raw(
                Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.VentasDiaLabels)
        );

    const diasData = @Html.Raw(
                Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.VentasDiaData)
        );

    new Chart(document.getElementById('diasChart'), {

            type: 'line',

            data: {
                labels: diasLabels,

                datasets: [{
                    label: 'Ventas',
                    data: diasData,
                    tension: 0.3
                }]
            },

            options: {
                responsive: true
            }
        });

    </script>
    <script>
        const labels = @Html.Raw(
                    Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GraficoLabels)
            );

    const data = @Html.Raw(
                Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GraficoData)
        );

    const ctx = document.getElementById('ventasChart');

        new Chart(ctx, {
            type: 'bar',

            data: {
                labels: labels,

                datasets: [{
                    label: 'Cantidad vendida',
                    data: data,
                    borderWidth: 1
                }]
            },

            options: {
                responsive: true,

                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
}



