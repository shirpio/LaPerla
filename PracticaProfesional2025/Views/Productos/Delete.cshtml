@model PracticaProfesional2025.Models.Producto

<h3 class="text-danger">Desactivar producto</h3>

<div class="alert alert-warning">
    ⚠️ Este producto no se eliminará definitivamente.
    <br />
    Quedará <strong>desactivado</strong> y no aparecerá en la lista principal,
    pero seguirá existiendo en reportes anteriores.
</div>

<dl class="row">
    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.Nombre</dd>

    <dt class="col-sm-3">Precio</dt>
    <dd class="col-sm-9">$@Model.Precio</dd>

    <dt class="col-sm-3">Tipo</dt>
    <dd class="col-sm-9">@Model.Tipo</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-warning">
        <i class="bi bi-slash-circle"></i> Desactivar
    </button>

    <a asp-action="Index" class="btn btn-secondary ms-2">
        Cancelar
    </a>
</form>

